  "useFetch Hook": {
    "prefix": "usefetch",
    "body": [
      "function useFetch<T>(url: string) {",
      "\tconst [data, setData] = useState<T | null>(null);",
      "\tconst [loading, setLoading] = useState(true);",
      "\tconst [error, setError] = useState<Error | null>(null);",
      "",
      "\tuseEffect(() => {",
      "\t\tlet cancelled = false;",
      "\t\tsetLoading(true);",
      "\t\tfetch(url)",
      "\t\t\t.then((res) => {",
      "\t\t\t\tif (!res.ok) throw new Error(`HTTP \\${res.status}`);",
      "\t\t\t\treturn res.json() as Promise<T>;",
      "\t\t\t})",
      "\t\t\t.then((d) => { if (!cancelled) setData(d); })",
      "\t\t\t.catch((e: Error) => { if (!cancelled) setError(e); })",
      "\t\t\t.finally(() => { if (!cancelled) setLoading(false); });",
      "\t\treturn () => { cancelled = true; };",
      "\t}, [url]);",
      "",
      "\treturn { data, loading, error };",
      "}"
    ],
    "description": "Generic typed useFetch hook"
  },
